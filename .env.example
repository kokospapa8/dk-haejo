# ── Discord ───────────────────────────────────────────────────────────────────
# Bot token from https://discord.com/developers/applications
DISCORD_TOKEN=your_discord_bot_token_here

# ── Anthropic ─────────────────────────────────────────────────────────────────
# API key from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Claude model to use (default: claude-opus-4-7)
CLAUDE_MODEL=claude-opus-4-7

# ── Music Channel IDs ─────────────────────────────────────────────────────────
# Comma-separated list of Discord channel IDs where ANY message is treated
# as a music command (no @mention needed).
# Right-click a channel in Discord (Developer Mode on) → Copy ID
# Leave empty to require @mention everywhere.
MUSIC_CHANNEL_IDS=123456789012345678,987654321098765432
